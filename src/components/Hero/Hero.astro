---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  texts: string[];
  image: ImageMetadata;
}

const { texts, image } = Astro.props;
---

<div class='px-4'>
  <section class='group mb-4 px-4 py-4 md:flex md:items-center md:justify-between md:gap-6'>
    <div
      class='relative mx-auto aspect-square w-2/3 min-w-64 max-w-96 shrink-0 grow overflow-clip rounded-full md:mx-0 md:max-w-72'
    >
      <Image
        src={image}
        alt='Profil picture'
        class='absolute h-full w-full object-cover grayscale transition-all group-hover:grayscale-0'
      />
    </div>
    <div class='px-4 font-mono text-2xl md:text-3xl'>
      {
        texts.map((text) => (
          <p class='mb-4 mt-2 text-xl font-light leading-8 text-gray-800'>{text}</p>
        ))
      }
    </div>
  </section>
  <hr class='h-2 border-b border-t-2 border-black bg-transparent px-4' />
</div>
