---
interface Props {
  text: string;
  title?: boolean;
}
const { text }: Props = Astro.props;
---

<div class='text-center'>
  {
    Astro.url.pathname === '/' ? (
      <h1 class='text-l relative top-3 inline border border-black bg-white px-4 py-2 font-sans font-light'>
        {text}
      </h1>
    ) : (
      <span class='text-l relative top-3 border border-black bg-white px-4 py-2 font-sans font-light'>
        {text}
      </span>
    )
  }
  <hr class='h-1 border-none bg-black' />
</div>
