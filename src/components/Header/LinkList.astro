---
import Link from '../Link.astro';

interface Props {
  items: {
    name: string;
    url: string;
  }[];
}

const { items } = Astro.props;
---

<ul class='flex gap-1 font-mono text-base'>
  {
    items.map((item, index) => (
      <>
        <li class='overflow-hidden '>
          <Link url={item.url} className='font-mono px-1 font-light'>
            {item.name}
          </Link>
        </li>
        {index !== items.length - 1 && <span class='text-black'>-</span>}
      </>
    ))
  }
</ul>
